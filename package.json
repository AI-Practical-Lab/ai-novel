{
  "name": "ai-novel-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "install:all": "npm install && npm run install:frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npm run install:all && concurrently \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
